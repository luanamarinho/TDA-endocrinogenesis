// ============================================================
// Nextflow configuration — Giotto-TDA Endocrinogenesis Pipeline
// Target executor: Azure Batch
// ============================================================

manifest {
    name            = 'Giotto-TDA/endocrinogenesis'
    description     = 'scRNA-seq QC, normalisation, HVG selection and UMAP on the scVelo pancreas dataset'
    version         = '0.1.0'
    nextflowVersion = '>=24.04.0'
    mainScript      = 'main.nf'
}

// ── Pipeline parameters ──────────────────────────────────────
params {
    outdir = './results'

    // QC thresholds
    min_genes    = 1200
    min_cells    = 20
    max_mt_perc  = 20.0

    // Normalization
    exclude_highly_expressed = true
    max_fraction             = 0.05
    target_sum               = null     // null → median total count

    // HVG selection
    n_top_genes = 4000
    flavor      = 'cell_ranger'         // cell_ranger | seurat | seurat_v3 | seurat_v3_paper

    // Dimensionality reduction
    dr_method         = 'umap'
    umap_metric       = 'euclidean'
    umap_random_state = 42
    n_components      = 40
}

// ── Process defaults & labels ────────────────────────────────
process {
    // Retry on OOM / transient failures
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2

    // process_low  — LOAD_DATA, QC_FILTER
    withLabel: process_low {
        cpus   = 2
        memory = { 8.GB  * task.attempt }
        time   = { 1.h   * task.attempt }
    }

    // process_medium — NORMALIZE_HVG (scanpy + scipy sparse ops)
    withLabel: process_medium {
        cpus   = 4
        memory = { 16.GB * task.attempt }
        time   = { 2.h   * task.attempt }
    }

    // process_high — DIMENSIONALITY_REDUCTION (umap-learn on 40-dim matrix)
    withLabel: process_high {
        cpus   = 8
        memory = { 32.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
}

// ── Azure Batch ───────────────────────────────────────────────
azure {
    storage {
        accountName = secrets.AZURE_STORAGE_ACCOUNT_NAME
        accountKey  = secrets.AZURE_STORAGE_ACCOUNT_KEY
    }

    batch {
        location    = 'centralspain'          //
        accountName = secrets.AZURE_BATCH_ACCOUNT_NAME
        accountKey  = secrets.AZURE_BATCH_ACCOUNT_KEY

        autoPoolMode      = true
        allowPoolCreation = true
    }
}

// Work directory in Azure Blob Storage
// workDir = 'az://tda/work'  // Azure only — override per profile

// ── Container runtime ─────────────────────────────────────────
docker {
    enabled    = true
    runOptions = "-u ${ ['id', '-u'].execute().text.trim() }:${ ['id', '-g'].execute().text.trim() }"
}

// ── Wave containers ───────────────────────────────────────────
wave {
    enabled  = false   // enabled per-profile (see azure profile)
    strategy = 'conda,container'
}

// ── Execution reports ─────────────────────────────────────────
report {
    enabled = true
    file    = "${params.outdir}/reports/execution_report_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/reports/execution_timeline_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/reports/execution_trace_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.txt"
    fields  = 'task_id,name,status,exit,realtime,%cpu,rss,vmem,peak_rss,peak_vmem'
}

// ── Profiles ──────────────────────────────────────────────────
profiles {

    // ── Local Docker testing ──────────────────────────────────
    local {
        process.executor = 'local'
        docker.enabled   = true

        process {
            withLabel: process_low    { cpus = 2; memory = 4.GB }
            withLabel: process_medium { cpus = 4; memory = 8.GB }
            withLabel: process_high   { cpus = 4; memory = 8.GB }
        }
    }

    // ── Conda (no Docker) ─────────────────────────────────────
    conda {
        conda.enabled    = true
        docker.enabled   = false
        process.executor = 'local'

        process {
            withLabel: process_low    { cpus = 2; memory = 4.GB }
            withLabel: process_medium { cpus = 4; memory = 8.GB }
            withLabel: process_high   { cpus = 4; memory = 8.GB }
        }
    }

    // ── Minimal test (reduced params) ─────────────────────────
    test {
        params {
            min_genes    = 200
            n_top_genes  = 500
            n_components = 5
        }
        process {
            withLabel: process_low    { cpus = 1; memory = 4.GB; time = 15.min }
            withLabel: process_medium { cpus = 1; memory = 4.GB; time = 15.min }
            withLabel: process_high   { cpus = 1; memory = 4.GB; time = 30.min }
        }
    }

    // ── Azure Batch production ────────────────────────────────
    azure {
        workDir = 'az://tda/work'
        process {
            executor = 'azurebatch'
            // Queue routing removed: Platform Forge CE manages a single
            // auto-scaling pool — named pools (low/medium/high) do not exist
        }
        docker.enabled = true
        wave.enabled   = true
    }
}
